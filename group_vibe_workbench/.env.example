# Group Vibe Workbench Configuration

# Data directory for storing user data, swarm data, etc.
# Default: ./workbench_data
# Dev mode will override this with workbench_data_dev_N
DATA_DIR=./workbench_data

# Network port for P2P communication
# Default: 9000
# Dev mode will use base_port + instance_index
NETWORK_PORT=9000

# mDNS service name for local discovery
# Default: _murmur._tcp
MDNS_SERVICE_NAME=_murmur._tcp

# Shared file path for collaboration
# Default: ../chat.ctx
SHARED_FILE_PATH=../chat.ctx

# Window settings
WINDOW_WIDTH=1280
WINDOW_HEIGHT=720

# Log level: trace, debug, info, warn, error
# Default: debug (in dev builds), info (in release builds)
LOG_LEVEL=info

# Enable JSON output for structured logging
JSON_OUTPUT=false
